{
  "name": "trading-platform",
  "version": "1.0.0",
  "description": "Trading platform - frontend + backend",
  "license": "ISC",
  "author": "",
  "type": "module",
  "private": true,
  "workspaces": [
    "app",
    "server",
    "worker"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=app",
    "dev:server": "npm run dev --workspace=server",
    "dev:worker": "npm run dev --workspace=worker",
    "dev:start": "concurrently \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev\"",
    "dev:stop": "taskkill /f /im node.exe",
    "start": "concurrently \"npm run start:server\" \"npm run start:worker\"",
    "start:server": "npm start --workspace=server",
    "start:worker": "npm start --workspace=worker",
    "test": "npm test --workspaces",
    "test:app": "npm test --workspace=app",
    "test:server": "npm test --workspace=server",
    "e2e": "npm run e2e --workspace=app",
    "install:all": "npm install && npm install --workspace=app && npm install --workspace=server && npm install --workspace=worker"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
