# Railway Backend API URL
# This will be set automatically by Railway when both services are deployed
VITE_API_URL=http://localhost:3001

# Alpha Engine Configuration
# URL for the alpha-engine internal read API
VITE_ALPHA_ENGINE_URL=http://localhost:8090

# API key for alpha-engine (same value as INTERNAL_READ_KEY on alpha-engine side)
# Leave empty for local development without authentication
VITE_ALPHA_ENGINE_KEY=7f4c2a91d8e63b5f0c1a7e94b2d65f3a9c8e1f47b6d2c0ea95f13b7d4a6e8c21