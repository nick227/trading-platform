generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Direction {
  buy
  sell
}

// ExecutionStatus enum removed — status is now a plain String column.
// Valid values: queued | processing | partially_filled | filled | cancelled | failed

enum BotEventType {
  rule_triggered
  decision_made
  execution_created
  execution_skipped
  error_occurred
}

enum ExecutionAuditEventType {
  execution_created
  claimed
  submit_attempted
  submit_confirmed
  cancel_requested
  reconciled
  partial_fill
  filled
  cancelled
  retry_scheduled
  failed
  risk_blocked
}

enum BotRuleType {
  price_threshold
  position_limit
  daily_loss
  market_hours
  cooldown
  trend_filter
  time_window
}

model Strategy {
  id          String   @id
  name        String
  description String
  type        String
  createdAt   DateTime @default(now())

  predictions Prediction[]
  bots       Bot[]
  executions Execution[]

  @@index([type])
}

model Prediction {
  id           String    @id
  strategyId   String
  ticker       String
  direction    Direction
  confidence   Float
  entryPrice   Float
  stopPrice    Float
  targetPrice  Float
  createdAt    DateTime  @default(now())
  regime       String
  reasoning    String

  strategy   Strategy   @relation(fields: [strategyId], references: [id])
  executions Execution[]

  @@index([ticker, createdAt])
  @@index([strategyId])
}

model Portfolio {
  id          String      @id
  userId      String      // Using STUB_USER_ID for now
  name        String
  cashBalance Decimal     @default(0) @db.Decimal(12, 2)
  totalValue  Decimal     @default(0) @db.Decimal(12, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  executions Execution[]
  bots       Bot[]
  equityPeak EquityPeak?

  @@index([createdAt])
  @@index([userId])
  @@index([updatedAt])
  @@index([totalValue])
}

model BotTemplate {
  id          String   @id  // stable slug, e.g. "tmpl_momentum_buy"
  name        String
  description String
  botType     String   // "rule_based" | "strategy_based"
  config      Json     // default { tickers, quantity, direction }
  rules       Json     // array of { name, type, config } — copied to BotRule on instantiation
  tags        Json?    // e.g. ["momentum", "long"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bots        Bot[]

  @@index([botType])
}

model Bot {
  id           String     @id
  userId       String
  portfolioId  String
  strategyId   String?    // null for rule_based bots
  templateId   String?    // which BotTemplate created this bot (null if created manually)
  botType      String     @default("rule_based") // "rule_based" | "strategy_based"
  name         String
  enabled      Boolean    @default(true)
  config       Json       // { tickers, quantity, direction }
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?  // Soft delete

  portfolio Portfolio    @relation(fields: [portfolioId], references: [id])
  strategy  Strategy?    @relation(fields: [strategyId], references: [id])
  template  BotTemplate? @relation(fields: [templateId], references: [id])
  rules     BotRule[]
  events    BotEvent[]
  executions Execution[]

  @@index([portfolioId])
  @@index([enabled])
  @@index([userId])
  @@index([templateId])
}

model BotRule {
  id        String      @id
  botId     String
  name      String
  type      BotRuleType
  config    Json        // Typed config based on type
  enabled   Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  bot Bot @relation(fields: [botId], references: [id])

  @@index([botId, enabled])
}

model BotEvent {
  id          String       @id
  botId       String
  portfolioId String       // Denormalized for performance
  ruleId      String?
  executionId String?
  type        BotEventType
  detail      String
  metadata    Json?        // Structured context
  createdAt   DateTime     @default(now())

  bot       Bot        @relation(fields: [botId], references: [id])
  execution Execution? @relation(fields: [executionId], references: [id])

  @@index([botId, createdAt])
  @@index([portfolioId, createdAt])
  @@index([executionId])
  @@index([type])
}

model Execution {
  id            String    @id
  userId        String    // required — maps to BrokerAccount.userId for credential lookup
  portfolioId   String
  strategyId    String?   // null for rule_based bot executions
  predictionId  String?
  botId         String?
  botRunId      Int?      // MVP: link to BotRun
  ticker        String
  direction     Direction
  quantity      Float
  price         Float     // intent price (what was seen at order time)
  origin        String    @default("manual") // 'manual' | 'bot'
  // Queue fields
  status        String    @default("queued") // queued | processing | partially_filled | filled | cancelled | failed
  scheduledFor  DateTime? // when this order should execute (UTC)
  lockedAt      DateTime? // = processingStartedAt: when worker claimed this row
  lockedBy      String?   // worker instance ID
  attempts      Int       @default(0)
  clientOrderId String?   @unique
  activeIntentKey String? @unique
  // Broker fields
  brokerOrderId  String?
  brokerStatus   String?
  submittedAt    DateTime?
  lastBrokerSyncAt DateTime?
  filledAt       DateTime?
  filledPrice    Float?   // truth: actual fill price from Alpaca
  filledQuantity Float?
  cancelReason   String?
  // Cancellation intent (user requested cancel). Worker attempts broker cancel when applicable.
  cancelRequestedAt DateTime?
  cancelRequestedBy String?
  cancelRequestReason String?
  // Cost fields
  commission    Float
  fees          Float
  // MVP fields
  signalScore   Decimal? @db.Decimal(3, 2)
  pnl           Decimal  @default(0) @db.Decimal(10, 2)
  // Attribution fields for metrics pipeline
  sourceType    String   @default("UNKNOWN") // 'MANUAL' | 'TEMPLATE' | 'CUSTOM_RULE' | 'ML_SIGNAL' | 'REBALANCE' | 'UNKNOWN'
  sourceId      String?  // templateId, botId, strategyId, userActionId
  isManual      Boolean  @default(false) // Legacy flag for backward compatibility
  createdAt     DateTime  @default(now())

  portfolio  Portfolio   @relation(fields: [portfolioId], references: [id])
  strategy   Strategy?   @relation(fields: [strategyId], references: [id])
  prediction Prediction? @relation(fields: [predictionId], references: [id])
  bot        Bot?        @relation(fields: [botId], references: [id])
  botRun     BotRun?     @relation(fields: [botRunId], references: [id])
  events     BotEvent[]
  audits     ExecutionAudit[]

  @@index([portfolioId, createdAt])
  @@index([ticker, createdAt])
  @@index([strategyId])
  @@index([botId, createdAt])
  @@index([status, lockedAt])          // worker claim query
  @@index([botId, ticker, status])     // bot engine inflight check (DB fallback)
  @@index([status, filledAt])          // daily loss rule: today's fills
  @@index([createdAt, id])             // cursor pagination
  @@index([userId])
}

model ExecutionAudit {
  id          String                  @id
  executionId String
  userId      String
  workerId    String?
  eventType   ExecutionAuditEventType
  detail      String
  metadata    Json?
  createdAt   DateTime                @default(now())

  execution Execution @relation(fields: [executionId], references: [id])

  @@index([executionId, createdAt])
  @@index([eventType, createdAt])
  @@index([userId, createdAt])
}

model BrokerAccount {
  id        String   @id
  userId    String   @unique
  broker    String   @default("alpaca")
  apiKey    String
  apiSecret String
  paper     Boolean  @default(true)
  status    String   @default("active") // active | error | disabled
  lastVerifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  fullName     String
  riskSettings Json?         // User-specific risk limits and preferences
  createdAt    DateTime      @default(now())
  subscription Subscription?
}

model Subscription {
  id     String   @id @default(cuid())
  userId String   @unique
  status String   @default("ACTIVE") // ACTIVE | CANCELLED | EXPIRED
  plan   String   @default("BASIC")
  endsAt DateTime
  user   User     @relation(fields: [userId], references: [id])
}

model WorkerStatus {
  id         String   @id  // hostname-pid
  lastSeen   DateTime
  startedAt  DateTime @default(now())
  queueLagMs Int?
  lastRestOkAt DateTime?
  lastWsOkAt DateTime?
  lastCalendarRefreshAt DateTime?
  health     Json?
}

// Daily market regime snapshots used by trend/regime bots.
// Written by the API server (Alpha Engine integration) and read by the worker.
model MarketRegime {
  id        String   @id @default(cuid())
  symbol    String
  asOf      DateTime // market day this snapshot represents (daily bar date)
  regime    String   // "risk_on" | "risk_off"
  score     Float?
  priceClose Float?
  sma20     Float?
  sma200    Float?
  inputsJson Json?
  createdAt DateTime @default(now())

  @@unique([symbol, asOf])
  @@index([symbol, asOf(sort: Desc)])
}

// MVP Tables for Single User Operator Mode

model BotRun {
  id           Int      @id @default(autoincrement())
  userId       String
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  status       String   @default("running") // running | completed | failed
  signalCount  Int      @default(0)
  executionCount Int    @default(0)
  totalPnl     Decimal  @default(0) @db.Decimal(10, 2)
  notes        String?
  executions   Execution[]
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

model DailySnapshot {
  id            Int      @id @default(autoincrement())
  snapshotDate  DateTime @unique @db.Date
  equity        Decimal  @db.Decimal(12, 2)
  cash          Decimal  @db.Decimal(12, 2)
  positionsValue Decimal @db.Decimal(12, 2)
  dayPnl        Decimal  @default(0) @db.Decimal(10, 2)
  totalTrades   Int      @default(0)
  winningTrades Int      @default(0)
  capturedAt    DateTime @default(now())

  @@index([snapshotDate])
}

// Metrics Pipeline Tables
model TradeMetricFact {
  id                  String   @id @default(cuid())
  date                DateTime @db.Date
  userId              String
  botId               String?
  templateId          String?
  sourceExecutionId   String   // Links to original execution
  eventType           String   // 'fill' | 'deposit' | 'withdrawal' | 'transfer'
  sourceType          String   // 'MANUAL' | 'TEMPLATE' | 'CUSTOM_RULE' | 'ML_SIGNAL' | 'REBALANCE' | 'UNKNOWN'
  sourceId            String?  // templateId, botId, strategyId, userActionId
  pnl                 Decimal  @db.Decimal(12, 2)
  returnPct           Decimal  @db.Decimal(8, 4)
  isWin               Boolean  @default(false)
  capitalUsed         Decimal  @db.Decimal(12, 2)
  holdingMinutes      Int
  direction           String   // 'buy' | 'sell'
  ticker              String
  quantity            Float
  entryPrice          Decimal  @db.Decimal(10, 4)
  exitPrice           Decimal  @db.Decimal(10, 4)
  dailyEquityReturn   Decimal  @db.Decimal(8, 6) // For proper Sharpe calculation
  allocatedCapital    Decimal  @db.Decimal(12, 2) // Return denominator
  cashFlowAmount      Decimal? @db.Decimal(12, 2) // For deposits/withdrawals
  portfolioValue      Decimal? @db.Decimal(12, 2) // Portfolio value after event
  processed           Boolean  @default(false) // Watermark replacement
  createdAt           DateTime @default(now())
  
  @@index([processed, createdAt])
  @@index([date])
  @@index([userId, date])
  @@index([templateId, date])
  @@index([sourceExecutionId])
  @@index([sourceType, sourceId])
}

model TemplateMetricDay {
  id                    String   @id @default(cuid())
  date                  DateTime @db.Date
  templateId            String
  activeUsers           Int      @default(0)
  activeBots            Int      @default(0)
  totalTrades           Int      @default(0)
  winningTrades         Int      @default(0)
  totalPnl              Decimal  @default(0) @db.Decimal(12, 2)
  totalReturn           Decimal  @default(0) @db.Decimal(8, 4)
  avgWinRate            Decimal  @default(0) @db.Decimal(5, 2)
  dailyEquityReturn     Decimal  @default(0) @db.Decimal(8, 6) // For Sharpe
  maxDrawdown           Decimal  @default(0) @db.Decimal(5, 2)
  startingEquity        Decimal  @default(0) @db.Decimal(12, 2) // Return denominator
  avgDeployedCapital    Decimal  @default(0) @db.Decimal(12, 2)
  dataQuality           String   @default("sufficient") // Data quality flag
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([date, templateId])
  @@index([templateId, date])
}

model SiteMetricDay {
  id                  String   @id @default(cuid())
  date                DateTime @db.Date @unique
  usersActive         Int      @default(0)
  templatesActive     Int      @default(0)
  botsActive          Int      @default(0)
  totalTrades         Int      @default(0)
  grossPnl            Decimal  @default(0) @db.Decimal(12, 2)
  totalVolume         Decimal  @default(0) @db.Decimal(15, 2)
  newUsers            Int      @default(0)
  churnedUsers        Int      @default(0)
  systemDailyReturn   Decimal  @default(0) @db.Decimal(8, 6)
  systemSharpe        Decimal  @default(0) @db.Decimal(5, 2)
  totalDeployedCapital Decimal @default(0) @db.Decimal(15, 2)
  
  @@index([date])
}

// Worker-refreshed current metrics table (MySQL-friendly)
model TemplateMetricCurrent {
  id                  String   @id @default(cuid())
  templateId          String   @unique
  totalTrades         Int      @default(0)
  winningTrades       Int      @default(0)
  totalPnl            Decimal  @default(0) @db.Decimal(12, 2)
  annualReturn        Decimal  @default(0) @db.Decimal(8, 4) // Based on allocated capital
  winRate             Decimal  @default(0) @db.Decimal(5, 2)
  sharpeRatio         Decimal  @default(0) @db.Decimal(5, 2) // From daily equity returns
  maxDrawdown         Decimal  @default(0) @db.Decimal(5, 2)
  activeUsers         Int      @default(0)
  last30dReturn       Decimal  @default(0) @db.Decimal(8, 4)
  avgDeployedCapital  Decimal  @default(0) @db.Decimal(12, 2)
  dataQuality         String   @default("insufficient_data") // Truth label
  lastUpdated         DateTime @default(now())
  
  @@index([templateId])
}

// Worker watermark tracking
model MetricWatermark {
  id                  String   @id @default(cuid())
  metricType          String   // 'template', 'site', 'user'
  lastProcessedAt     DateTime @default(now())
  lastProcessedId     String?
  isDirty             Boolean  @default(false) // For nightly recalculation
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@unique([metricType])
}

// Live quote cache from worker - enables server to access real-time prices
model LiveQuote {
  ticker      String   @id
  bid         Float?
  ask         Float?
  last        Float
  changePct   Float    @default(0)
  volume      Int      @default(0)
  updatedAt   DateTime @default(now())
  source      String   @default("worker") // worker | alpha-engine | manual
  feed        String   @default("alpaca")  // alpaca | yahoo | polygon
  ageMs       Int      @default(0)       // Age from source in milliseconds

  @@index([updatedAt])
  @@index([source])
}

// Subscription requests for demand-driven quote warmup
model LiveQuoteSubscription {
  ticker      String   @id
  requestedAt DateTime @default(now())

  @@index([requestedAt])
}

// Lightweight discovery universe for low-price and watchlist cards.
model DiscoverySymbol {
  symbol               String   @id
  name                 String?
  marketCap            Float?
  avgVolume            Float?
  lastPrice            Float?
  sector               String?
  industry             String?
  isTradable           Boolean  @default(false)
  tradableBroker       String?
  untradableReason     String?
  source               String   @default("manual")
  lastProfileRefreshAt DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([lastPrice])
  @@index([isTradable, lastPrice])
  @@index([marketCap])
  @@index([updatedAt])
}

// Execution reservations for atomic risk management
model ExecutionReservation {
  id          String   @id
  portfolioId String
  status      String   @default("active") // active | released | expired
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  releasedAt  DateTime?

  @@index([portfolioId, status])
  @@index([expiresAt])
  @@index([status])
}

// Equity peaks for proper drawdown calculation
model EquityPeak {
  id          String   @id @default(cuid())
  portfolioId String
  peakEquity  Decimal  @db.Decimal(12, 2)
  peakDate    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id])

  @@unique([portfolioId]) // One peak per portfolio
  @@index([peakDate])
  @@index([updatedAt])
}

// Cached correlation matrix for performance
model CorrelationCache {
  id             String   @id @default(cuid())
  ticker1        String
  ticker2        String
  correlation    Decimal  @db.Decimal(10, 6)
  calculatedAt   DateTime
  dataPoints     Int
  periodDays     Int      @default(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([ticker1, ticker2, periodDays])
  @@index([ticker1])
  @@index([ticker2])
  @@index([calculatedAt])
  @@index([periodDays])
}

// Sector exposure limits
model SectorExposureLimit {
  id                    String   @id @default(cuid())
  portfolioId           String
  sector                String
  maxExposurePercent    Decimal  @db.Decimal(5, 2)
  currentExposurePercent Decimal  @db.Decimal(5, 2) @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([portfolioId, sector])
  @@index([portfolioId])
  @@index([sector])
}

// Ticker concentration limits
model TickerConcentrationLimit {
  id                    String   @id @default(cuid())
  portfolioId           String
  ticker                String
  maxExposurePercent    Decimal  @db.Decimal(5, 2)
  currentExposurePercent Decimal  @db.Decimal(5, 2) @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([portfolioId, ticker])
  @@index([portfolioId])
  @@index([ticker])
}
