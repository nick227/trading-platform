    "id": "tmpl_momentum_buy",
    "name": "Momentum Buy",
    "description": "Buys a ticker when price rises above a configurable threshold. Enforces market hours, position limits, and a per-ticker cooldown to prevent overtrading.",
    "botType": "rule_based",
    "tags": ["momentum", "long", "threshold"],
    "config": {
      "direction": "buy",
      "quantity": 1,
      "tickers": []
    },
    "rules": [
      {
        "name": "Market Hours",
        "type": "market_hours",
        "config": { "allowPremarket": false, "allowAfterHours": false }
      },
      {
        "name": "Price Above Threshold",
        "type": "price_threshold",
        "config": { "direction": "above", "price": 0 }
      },
      {
        "name": "Position Limit",
        "type": "position_limit",
        "config": { "maxShares": 100 }
      },
      {
        "name": "Cooldown",
        "type": "cooldown",
        "config": { "windowMs": 3600000 }
      }
    ]
  },
