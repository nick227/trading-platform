{
  "name": "trading-platform-server",
  "version": "1.0.0",
  "description": "Trading platform backend API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "npm run db:generate && node src/server.js",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed:discovery": "node scripts/seedDiscoverySymbols.js",
    "db:studio": "prisma studio",
    "ops:cleanup-workers": "node scripts/cleanupWorkerStatus.js",
    "ops:soak": "node scripts/openMarketSoak.js"
  },
  "dependencies": {
    "@fastify/compress": "^7.0.3",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/swagger": "^8.12.0",
    "@fastify/swagger-ui": "^2.0.0",
    "@prisma/client": "^5.6.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "fastify": "^4.24.3",
    "prisma": "^5.6.0"
  },
  "devDependencies": {
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
